{
  "margin-top": "30%",
  "margin-bottom": "30%",
  "margin-left": "15%",
  "margin-right": "15%",
  "buttons-per-row": "1/1",
  "column-spacing": "20px",
  "row-spacing": "20px",
  "close-on-lost-focus": true,
  "buttons": [
    {
      "label": "lock",
      "action": "hyprlock",
      "text": "Lock",
      "keybind": "l",
      "icon": "/usr/share/wleave/icons/lock.svg"
    },
    {
      "label": "suspend",
      "action": "systemctl suspend",
      "text": "Suspend",
      "keybind": "s",
      "icon": "/usr/share/wleave/icons/suspend.svg"
    },
    {
      "label": "shutdown",
      "action": "systemctl poweroff",
      "text": "Shutdown",
      "keybind": "p",
      "icon": "/usr/share/wleave/icons/shutdown.svg"
    },
    {
      "label": "reboot",
      "action": "systemctl reboot",
      "text": "Reboot",
      "keybind": "r",
      "icon": "/usr/share/wleave/icons/reboot.svg"
    }
  ]
}